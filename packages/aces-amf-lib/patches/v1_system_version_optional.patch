# Patch: v1_system_version_optional
#
# What: Makes PipelineInfoType.system_version optional (None | VersionType).
#
# Why: Legacy v1 AMF files often omit <systemVersion>, which causes parse
#      failures when the field is required. The v1->v2 upgrade function in
#      amf_helpers.py injects a default value before conversion.
#
# If this patch fails: regenerate with ./generate_bindings.sh --gen-patches

--- aces_metadata_file.py
+++ aces_metadata_file.py
@@ -234,7 +234,8 @@
         name = "pipelineInfoType"
 
     model_config = ConfigDict(defer_build=True)
-    system_version: VersionType = field(
+    system_version: None | VersionType = field(
+        default=None,
         metadata={
             "name": "systemVersion",
             "type": "Element",
